{
  "name": "byte-bit-tool",
  "displayName": "Byte Bit Tool",
  "description": "Convert numbers between DEC, HEX and BIN with bitwise operations support",
  "version": "0.0.4",
  "publisher": "mishaels",
  "author": {
    "name": "MishaelS",
    "email": "user.name@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MishaelS/bbt-extension"
  },
  "homepage": "https://github.com/MishaelS/bbt-extension",
  "bugs": {
    "url": "https://github.com/MishaelS/bbt-extension/issues"
  },
  "keywords": [
    "converter",
    "binary",
    "hexadecimal",
    "decimal",
    "bitwise",
    "calculator"
  ],
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "main": "./out/extension.js",
  "configuration": {
    "title": "Byte Bit Tool",
    "properties": {
      "byteBitTool.autoSave": {
        "type": "boolean",
        "default": false,
        "description": "Automatically save calculations to history while typing. When disabled, press Enter to save."
      }
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "byte-bit-tool.open",
        "title": "Open Byte Bit Tool",
        "category": "Byte Bit Tool",
        "icon": "$(symbol-number)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "byte-bit-tool",
          "title": "Byte Bit Tool",
          "icon": "$(symbol-number)"
        }
      ]
    },
    "views": {
      "byte-bit-tool": [
        {
          "id": "byte-bit-tool.view",
          "name": "Byte Bit Tool"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "byte-bit-tool.open"
        }
      ],
      "view/title": [
        {
          "command": "byte-bit-tool.open",
          "when": "view == byte-bit-tool.view",
          "group": "navigation",
          "icon": "$(open-preview)"
        }
      ],
      "editor/title": [
        {
          "command": "byte-bit-tool.open",
          "group": "navigation",
          "icon": "$(symbol-number)"
        }
      ]
    },
    "keybindings": [
      {
        "command": "byte-bit-tool.open",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "eslint": "^10.2.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1"
  }
}